{
  "name": "opencode-tools",
  "version": "1.0.0",
  "description": "OpenCode Tools - MCP-based Developer Team Automation",
  "main": "dist/index.js",
  "bin": {
    "opencode-tools": "./dist/src/cli.js",
    "oct": "./dist/src/cli.js"
  },
  "preferGlobal": true,
  "scripts": {
    "build": "tsc && node dist/scripts/copy-assets.js",
    "dev": "npm run mcp",
    "mcp": "node dist/tools/mcp-server.js",
    "start": "npm run mcp",
    "test": "jest --clearCache && jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns='unit/'",
    "test:integration": "jest --testPathPatterns='integration/'",
    "test:e2e": "jest --testPathPatterns='e2e/' --runInBand",
    "test:security": "jest --testPathPatterns='security/' --passWithNoTests",
    "test:performance": "jest --testPathPatterns='performance/'",
    "test:load": "jest --testPathPatterns='load/'",
    "test:mutation": "stryker run",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:security",
    "lint": "eslint src/**/*.ts agents/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts agents/**/*.ts tests/**/*.ts --fix",
    "verify": "node dist/src/cli.js verify",
    "doctor": "node dist/src/cli.js doctor",
    "postinstall": "node dist/scripts/post-install.js || true",
    "validate:deliverable-scope": "node scripts/validate-deliverable-scope.js",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "validate": "npm run lint && npm run build && npm run validate:deliverable-scope && npm run test:unit"
  },
  "keywords": [
    "opencode",
    "automation",
    "mcp",
    "cli",
    "developer-tools",
    "ai-assistants"
  ],
  "author": "OpenCode Tools Team",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^27.5.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.33",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@wonderwhy-er/desktop-commander": "^0.2.38",
    "eslint": "^10.0.1",
    "jest": "^30.2.0",
    "mcp-remote": "^0.1.38",
    "next-devtools-mcp": "^0.3.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@types/handlebars": "^4.1.0",
    "@types/html-to-text": "^9.0.4",
    "archiver": "^4.0.2",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "commander": "^11.0.0",
    "docx": "^9.5.3",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.1.1",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "mermaid": "^11.12.2",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.34.5",
    "strip-ansi": "^7.1.2",
    "testcontainers": "^10.2.2",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "prompts/**/*",
    "mcp/**/*",
    "docs/**/*",
    "opencode.json",
    "opencode-system-prompt.md",
    "README.md",
    "AGENTS.md",
    "INTEGRATION_GUIDE.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "type": "commonjs",
  "types": "./dist/index.d.ts"
}
